# ── Required for execution ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
EXEC_MODEL_PROVIDER=anthropic
EXEC_MODEL_NAME=claude-haiku-4-5-20251001

# ── Required for Gemini judging when JUDGE_MODEL=gemini ───────────
# No hidden judge fallback is allowed. If Gemini judging is selected
# without this key, the benchmark should fail closed.
GEMINI_API_KEY=
JUDGE_MODEL=gemini

# ── Optional: Qwen via DashScope OpenAI-compatible API ────────────
# To use Qwen for execution or judging, switch EXEC_MODEL_PROVIDER=qwen and/or
# JUDGE_MODEL=qwen explicitly. No hidden fallback is allowed.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_EXEC_MODEL=qwen-plus
QWEN_JUDGE_MODEL=qwen-plus
# Optional cost accounting for Qwen models in USD per million tokens.
# QWEN_INPUT_PER_MTOK=
# QWEN_OUTPUT_PER_MTOK=

# ── GitHub (free, 5000 req/hr) ────────────────────────────────────
# Create at: https://github.com/settings/tokens → classic token, no scopes needed
GITHUB_TOKEN=ghp_...

# ── Admin & CORS ─────────────────────────────────────────────────
ADMIN_API_KEY=changeme-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Optional (not needed for MVP) ─────────────────────────────────
YOUTUBE_API_KEY=
ONET_USERNAME=
ONET_PASSWORD=
